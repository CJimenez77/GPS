graph TB
    subgraph DEV["Desarrollo local"]
        DC["docker-compose up\nms-req + ms-users + ms-reports + PostgreSQL"]
    end

    subgraph CICD["CI/CD Pipeline"]
        GH["GitHub\nrepositorio central"]
        GA["GitHub Actions\nbuild→lint→test→docker→deploy\nSprint 1"]
        JK["Jenkins\nOracle Cloud Free Tier\nSprint 2"]
        GH -->|"push webhook"| GA
        GH -->|"push webhook Sprint 2"| JK
    end

    subgraph RAILWAY["Railway — Hosting gratuito"]
        MSR["ms-requirements\nNode 18 + Express\nDocker :3001"]
        MSU["ms-users\nNode 18 + Express\nDocker :3002"]
        MSRP["ms-reports\nNode 18 + Express\nDocker :3003"]
        PG[("PostgreSQL\nDrizzle ORM\nlógica transaccional")]
        MSR --- PG
        MSU --- PG
    end

    subgraph SHAREPOINT["SharePoint Online — Tenant de Cristian"]
